{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cleepboard",
  "version": "0.1.0",
  "identifier": "com.cleepboard.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cleepboard",
        "width": 380,
        "height": 540,
        "minWidth": 360,
        "minHeight": 300,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Lightweight clipboard manager",
    "longDescription": "Cleepboard is a lightweight, design-first clipboard history manager for Linux."
  }
}
